{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mokivan.github.io/mcpmatrix/schemas/mcpmatrix-config.schema.json",
  "title": "mcpmatrix Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["servers", "scopes"],
  "properties": {
    "servers": {
      "type": "object",
      "description": "Canonical MCP server definitions keyed by server name.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/serverDefinition"
      }
    },
    "scopes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "tags", "repos"],
      "properties": {
        "global": {
          "$ref": "#/$defs/globalScope"
        },
        "tags": {
          "type": "object",
          "default": {},
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/tagScope"
          }
        },
        "repos": {
          "type": "object",
          "default": {},
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/repoScope"
          }
        }
      }
    }
  },
  "$defs": {
    "configString": {
      "type": "string",
      "minLength": 1
    },
    "stringMap": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/configString"
      }
    },
    "serverNameList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "remoteAuth": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "none"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "token"],
          "properties": {
            "type": {
              "const": "bearer"
            },
            "token": {
              "$ref": "#/$defs/configString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "oauth"
            },
            "clientId": {
              "$ref": "#/$defs/configString"
            },
            "clientSecret": {
              "$ref": "#/$defs/configString"
            },
            "callbackPort": {
              "type": "integer",
              "minimum": 1
            },
            "metadataUrl": {
              "$ref": "#/$defs/configString"
            }
          }
        }
      ]
    },
    "stdioServerDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "command"],
      "properties": {
        "transport": {
          "const": "stdio"
        },
        "command": {
          "$ref": "#/$defs/configString"
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/configString"
          },
          "default": []
        },
        "env": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "remoteServerDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "protocol", "url"],
      "properties": {
        "transport": {
          "const": "remote"
        },
        "protocol": {
          "enum": ["auto", "http", "sse"]
        },
        "url": {
          "$ref": "#/$defs/configString"
        },
        "headers": {
          "$ref": "#/$defs/stringMap"
        },
        "auth": {
          "$ref": "#/$defs/remoteAuth"
        }
      }
    },
    "serverDefinition": {
      "oneOf": [
        {
          "$ref": "#/$defs/stdioServerDefinition"
        },
        {
          "$ref": "#/$defs/remoteServerDefinition"
        }
      ]
    },
    "globalScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable": {
          "$ref": "#/$defs/serverNameList"
        }
      },
      "default": {
        "enable": []
      }
    },
    "tagScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable": {
          "$ref": "#/$defs/serverNameList"
        }
      },
      "default": {
        "enable": []
      }
    },
    "repoScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "enable": {
          "$ref": "#/$defs/serverNameList"
        }
      },
      "default": {
        "tags": [],
        "enable": []
      }
    }
  }
}

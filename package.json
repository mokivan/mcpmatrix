{
  "name": "@mokivan/mcpmatrix",
  "version": "1.1.0",
  "license": "MIT",
  "description": "Define MCP servers once and generate configs for Codex, Claude Code, and Gemini from a canonical MCP configuration",
  "type": "commonjs",
  "keywords": [
    "mcp",
    "codex",
    "claude",
    "gemini",
    "cli",
    "config"
  ],
  "homepage": "https://github.com/mokivan/mcpmatrix#readme",
  "bugs": {
    "url": "https://github.com/mokivan/mcpmatrix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mokivan/mcpmatrix.git"
  },
  "author": "mokivan",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "bin": {
    "mcpmatrix": "dist/cli/index.js",
    "mmx": "dist/cli/index.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "node scripts/smoke.mjs",
    "pack:check": "node scripts/verify-package.mjs",
    "prepublishOnly": "npm run build && npm run lint && npm run typecheck && npm test && npm run test:smoke && npm run pack:check"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "toml": "^4.1.1",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.24.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.2.4"
  }
}
